# Puerto del servidor
PORT=4000

# Clave secreta para JWT (usar openssl rand -hex 64 para generar una segura)
JWT_SECRET=cambia_esto_por_un_secreto_muy_largo_y_aleatorio_de_al_menos_64_caracteres

# Tiempo de expiración del token JWT
JWT_EXPIRES_IN=2h

# Credenciales iniciales del admin (solo para seed)
ADMIN_EMAIL=admin@juanino.dev
ADMIN_PASSWORD=CambiaEstaPasswordAhora123!

# Origen permitido para CORS (frontend)
CORS_ORIGIN=http://localhost:5173

# Entorno
NODE_ENV=development
